# Supabase Configuration
# Lấy tại: Supabase Dashboard → Settings → API → Project URL & anon/public key
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google Gemini API Key (used for the AI chatbot shown to guests and customers)
# Get your key at: https://aistudio.google.com/app/apikey
# IMPORTANT: Copy this file to ".env.local" and fill in your actual keys.
# Vite reads variables from .env.local – changes to .env.example are NOT picked up automatically.
VITE_GEMINI_API_KEY=

# OnePay Vietnam Payment Gateway (optional – can also be configured in Settings → Thanh toán)
# Đăng ký tại: https://www.onepay.vn/
# Lưu ý bảo mật: VITE_ONEPAY_HASH_KEY là thông tin nhạy cảm; không commit vào source code
VITE_ONEPAY_MERCHANT=
VITE_ONEPAY_ACCESS_CODE=
VITE_ONEPAY_HASH_KEY=
