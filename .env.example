# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Google reCAPTCHA v3 Standard Site Key (used for Firebase phone auth / OTP)
# Loaded via the standard v3 script in index.html: https://www.google.com/recaptcha/api.js?render=SITE_KEY
VITE_RECAPTCHA_SITE_KEY=6Lc-vIosAAAAAPJ1NRFhFu43lldk12EAjgii-8Ke

# Google Gemini API Key (used for the AI chatbot shown to guests and customers)
# Get your key at: https://aistudio.google.com/app/apikey
# IMPORTANT: Copy this file to ".env.local" and fill in your actual keys.
# Vite reads variables from .env.local – changes to .env.example are NOT picked up automatically.
VITE_GEMINI_API_KEY=
