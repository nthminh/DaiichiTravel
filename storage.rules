rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Tour images: public read, validated write (images only, max 5 MB)
    match /tours/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Route images: public read, validated write (images only, max 5 MB)
    match /routes/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Chat audio: authenticated read/write (voice messages, max 10 MB)
    match /chatAudio/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size <= 10 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    // Addon/service images: public read, validated write (images only, max 5 MB)
    match /addonImages/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // All other paths: public read only; no unauthenticated writes
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}