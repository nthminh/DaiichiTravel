rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for Rowy user roles safely.
    function isRowyUserWithRole(role) {
      let userDocPath = /databases/$(database)/documents/_rowy_/userManagement/users/$(request.auth.uid);
      return request.auth != null &&
             exists(userDocPath) &&
             (get(userDocPath).data.roles.hasAny([role, 'admin']));
    }
    
    function isRowyAdmin() {
        let userDocPath = /databases/$(database)/documents/_rowy_/userManagement/users/$(request.auth.uid);
        return request.auth != null &&
             exists(userDocPath) &&
             get(userDocPath).data.roles.hasAny(['admin']);
    }

    // Field validation helpers – defend against oversized or malformed data.
    function isShortString(val) {
      return val is string && val.size() <= 200;
    }

    function isNonNegativeNumber(val) {
      return val is number && val >= 0;
    }

    function isValidBooking(data) {
      return isShortString(data.customerName)
          && isShortString(data.customerPhone)
          && isNonNegativeNumber(data.totalAmount)
          && isShortString(data.status);
    }

    function isValidTrip(data) {
      return isShortString(data.route)
          && isShortString(data.time)
          && isShortString(data.date)
          && isNonNegativeNumber(data.price);
    }

    function isValidRoute(data) {
      return isShortString(data.name)
          && isShortString(data.departurePoint)
          && isShortString(data.arrivalPoint)
          && isNonNegativeNumber(data.price);
    }

    function isValidAgent(data) {
      return isShortString(data.name)
          && isShortString(data.code)
          && isShortString(data.status);
    }

    function isValidConsignment(data) {
      return isShortString(data.senderName)
          && isShortString(data.receiverName)
          && isShortString(data.status);
    }

    // Rules for Rowy's internal collections.
    match /_rowy_/{collection}/{document=**} {
      allow read, write: if isRowyAdmin();
    }
    
    // --- App Collections ---

    // Trips: public read + validated write (for seat booking from app)
    match /trips/{trip} {
      allow read: if true;
      allow create: if request.resource.data.keys().size() <= 30
                    && isValidTrip(request.resource.data);
      allow update: if request.resource.data.keys().size() <= 30
                    && isValidTrip(request.resource.data);
      allow delete: if true;
    }

    // Routes: public read + validated write
    match /routes/{route} {
      allow read: if true;
      allow create: if request.resource.data.keys().size() <= 30
                    && isValidRoute(request.resource.data);
      allow update: if request.resource.data.keys().size() <= 30
                    && isValidRoute(request.resource.data);
      allow delete: if true;
    }

    match /vehicles/{vehicle} {
      allow read: if true;
      allow write: if true;
    }
    match /stops/{stop} {
      allow read: if true;
      allow write: if true;
    }
    match /tours/{tour} {
      allow read: if true;
      allow write: if true;
    }

    // Fare table: routeFares/{routeId}/fares/{fareDocId}
    // Public read so the booking form can look up fares without auth.
    // Public write so admin can manage fare tables from the app UI.
    match /routeFares/{routeId}/fares/{fareDocId} {
      allow read: if true;
      allow write: if true;
    }

    // Consignments: validated write
    match /consignments/{consignment} {
      allow read: if true;
      allow create: if request.resource.data.keys().size() <= 30
                    && isValidConsignment(request.resource.data);
      allow update: if request.resource.data.keys().size() <= 30
                    && isValidConsignment(request.resource.data);
      allow delete: if true;
    }

    // Agents: public read + validated write
    match /agents/{agent} {
      allow read: if true;
      allow create: if request.resource.data.keys().size() <= 30
                    && isValidAgent(request.resource.data);
      allow update: if request.resource.data.keys().size() <= 30
                    && isValidAgent(request.resource.data);
      allow delete: if true;
    }

    // Bookings: validated create/update; all operations for app UI
    match /bookings/{booking} {
      allow read: if true;
      allow create: if request.resource.data.keys().size() <= 30
                    && isValidBooking(request.resource.data);
      allow update: if request.resource.data.keys().size() <= 30
                    && isValidBooking(request.resource.data);
      allow delete: if true;
    }

    match /invoices/{invoice} {
      allow read, write: if true;
    }
    match /settings/{setting} {
      allow read, write: if true;
    }

    // Block all other paths not explicitly listed above (recursive wildcard)
    match /{path=**} {
      allow read, write: if false;
    }
  }
}