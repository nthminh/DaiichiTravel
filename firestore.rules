rules_version = '2';

service cloud.firestore {
  match /databases/daiichi-asia/documents {

    // Helper function to check for Rowy user roles safely.
    function isRowyUserWithRole(role) {
      let userDocPath = /databases/daiichi-asia/documents/_rowy_/userManagement/users/$(request.auth.uid);
      return request.auth != null &&
             exists(userDocPath) &&
             (get(userDocPath).data.roles.hasAny([role, 'admin']));
    }
    
    function isRowyAdmin() {
        let userDocPath = /databases/daiichi-asia/documents/_rowy_/userManagement/users/$(request.auth.uid);
        return request.auth != null &&
             exists(userDocPath) &&
             get(userDocPath).data.roles.hasAny(['admin']);
    }

    // Require the caller to hold a valid Firebase Auth token.
    // Every app user (admin, agent, customer, guest) receives an anonymous token
    // on login, so this blocks raw unauthenticated REST/SDK calls from the internet.
    function isSignedIn() {
      return request.auth != null;
    }

    // Field validation helpers – defend against oversized or malformed data.
    function isShortString(val) {
      return val is string && val.size() <= 200;
    }

    function isNonNegativeNumber(val) {
      return val is number && val >= 0;
    }

    function isValidBooking(data) {
      return isShortString(data.customerName)
          && isShortString(data.phone)
          && isNonNegativeNumber(data.amount)
          && isShortString(data.status);
    }

    function isValidTrip(data) {
      return isShortString(data.route)
          && isShortString(data.time)
          && isShortString(data.date)
          && isNonNegativeNumber(data.price);
    }

    function isValidRoute(data) {
      return isShortString(data.name)
          && isShortString(data.departurePoint)
          && isShortString(data.arrivalPoint)
          && isNonNegativeNumber(data.price);
    }

    function isValidAgent(data) {
      return isShortString(data.name)
          && isShortString(data.code)
          && isShortString(data.status);
    }

    function isValidConsignment(data) {
      return isShortString(data.senderName)
          && isShortString(data.receiverName)
          && isShortString(data.status);
    }

    function isValidInquiry(data) {
      return isShortString(data.name)
          && isShortString(data.phone)
          && isShortString(data.from)
          && isShortString(data.to)
          && data.keys().size() <= 30;
    }

    // Rules for Rowy's internal collections.
    match /_rowy_/{collection}/{document=**} {
      allow read, write: if isRowyAdmin();
    }
    
    // --- App Collections ---

    // Daily schedules: public read (aggregated trip list per day, used by booking page and ops)
    // Only authenticated users may write (schedule updates are admin-only).
    match /daily_schedules/{date} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Trips: public read + authenticated validated write (for management)
    // Seat-only updates (status change during booking) are allowed without auth.
    match /trips/{trip} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.keys().size() <= 30
                    && isValidTrip(request.resource.data);
      // Allow seat-only updates without auth (booking flow); full updates require auth.
      // The seats array size is bounded to prevent arbitrary inflation.
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seats'])
                        && request.resource.data.seats.size() <= 100)
                    || (isSignedIn()
                        && request.resource.data.keys().size() <= 30
                        && isValidTrip(request.resource.data));
      allow delete: if isSignedIn();
    }

    // Routes: public read + authenticated validated write
    match /routes/{route} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.keys().size() <= 40
                    && isValidRoute(request.resource.data);
      allow update: if isSignedIn()
                    && request.resource.data.keys().size() <= 40
                    && isValidRoute(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /vehicles/{vehicle} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /vehicleTypes/{vehicleType} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /stops/{stop} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /tours/{tour} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Fare table: routeFares/{routeId}/fares/{fareDocId}
    // Public read so the booking form can look up fares without auth.
    // Authenticated write so only app users can manage fare tables.
    match /routeFares/{routeId}/fares/{fareDocId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Per-seat fare overrides: routeSeatFares/{routeId}/seats/{fareDocId}
    // Public read so the booking page can apply seat-specific prices without auth.
    // Authenticated write so only app users can manage seat fare overrides.
    match /routeSeatFares/{routeId}/seats/{fareDocId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Consignments: authenticated validated write
    match /consignments/{consignment} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.keys().size() <= 30
                    && isValidConsignment(request.resource.data);
      allow update: if isSignedIn()
                    && request.resource.data.keys().size() <= 30
                    && isValidConsignment(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Agents: public read + authenticated validated write
    match /agents/{agent} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.keys().size() <= 30
                    && isValidAgent(request.resource.data);
      allow update: if isSignedIn()
                    && request.resource.data.keys().size() <= 30
                    && isValidAgent(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Bookings: anyone can create/update (book tickets without login); delete requires auth
    match /bookings/{booking} {
      allow read: if true;
      allow create: if request.resource.data.keys().size() <= 50
                    && isValidBooking(request.resource.data);
      allow update: if request.resource.data.keys().size() <= 50
                    && isValidBooking(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Inquiries: anyone can create (customers contacting about unavailable trips); read requires auth
    match /inquiries/{inquiry} {
      allow read: if isSignedIn();
      allow create: if isValidInquiry(request.resource.data);
    }

    // Employees and customers: public read (needed for login verification), authenticated write
    match /employees/{employee} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /customers/{customer} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // User guides: public read (help content), authenticated write
    match /userGuides/{guide} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /invoices/{invoice} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Driver assignments: authenticated read/write (managers assign, drivers respond)
    match /driverAssignments/{assignment} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll(['tripId', 'seatId', 'driverEmployeeId', 'driverName', 'status', 'assignedAt'])
                    && request.resource.data.keys().size() <= 30
                    && isShortString(request.resource.data.driverName)
                    && isShortString(request.resource.data.status);
      allow update: if isSignedIn() && request.resource.data.keys().size() <= 30;
      allow delete: if isSignedIn();
    }

    // Staff messages: authenticated read/write (internal messaging)
    // Supports text messages (content non-empty) and voice messages (voiceUrl present, content may be empty)
    match /staffMessages/{message} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll(['senderId', 'senderName', 'content', 'createdAt'])
                    && request.resource.data.keys().size() <= 25
                    && isShortString(request.resource.data.content)
                    && isShortString(request.resource.data.senderName)
                    && (request.resource.data.content.size() > 0
                        || (request.resource.data.keys().hasAny(['voiceUrl'])
                            && request.resource.data.voiceUrl is string
                            && request.resource.data.voiceUrl.matches('https://firebasestorage\\.googleapis\\.com/.*')));
      allow delete: if isSignedIn();
    }
    // Settings: public read (needed for login credential check), authenticated write
    match /settings/{setting} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Customer categories: public read (used in booking & registration forms), authenticated write
    match /customerCategories/{category} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Category verification requests: authenticated read/write
    // Customers submit requests; staff/managers review and update them.
    // Deletion is not permitted – requests are retained for audit purposes.
    match /categoryRequests/{request} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.keys().size() <= 20
                    && isShortString(request.resource.data.customerName)
                    && isShortString(request.resource.data.status);
      allow update: if isSignedIn()
                    && request.resource.data.keys().size() <= 20
                    && isShortString(request.resource.data.customerName)
                    && isShortString(request.resource.data.status);
    }

    // Audit logs: authenticated read, authenticated create-only (immutable audit trail)
    match /auditLogs/{log} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.keys().size() <= 20
                    && isShortString(request.resource.data.actorName)
                    && isShortString(request.resource.data.action);
      allow update, delete: if false;
    }

    // Properties (cruise ships, resorts, homestays): public read, authenticated write
    match /properties/{property} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    // Room types subcollection of each property
    match /properties/{property}/room_types/{roomType} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Pending payments (QR payment sessions): anyone can create/read/delete (guest booking flow),
    // signed-in users can update (admin confirmation or OnePay IPN).
    match /pendingPayments/{paymentRef} {
      allow read: if true;
      allow create: if request.resource.data.keys().size() <= 15
                    && isShortString(request.resource.data.paymentRef)
                    && isNonNegativeNumber(request.resource.data.expectedAmount)
                    && isShortString(request.resource.data.customerName);
      allow update: if isSignedIn() && request.resource.data.keys().size() <= 15;
      allow delete: if true;
    }

    // Block all other paths not explicitly listed above (recursive wildcard)
    match /{path=**} {
      allow read, write: if false;
    }
  }
}