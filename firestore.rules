rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for Rowy user roles safely.
    function isRowyUserWithRole(role) {
      let userDocPath = /databases/$(database)/documents/_rowy_/userManagement/users/$(request.auth.uid);
      return request.auth != null &&
             exists(userDocPath) &&
             (get(userDocPath).data.roles.hasAny([role, 'admin']));
    }
    
    function isRowyAdmin() {
        let userDocPath = /databases/$(database)/documents/_rowy_/userManagement/users/$(request.auth.uid);
        return request.auth != null &&
             exists(userDocPath) &&
             get(userDocPath).data.roles.hasAny(['admin']);
    }

    // Rules for Rowy's internal collections.
    match /_rowy_/{collection}/{document=**} {
      allow read, write: if isRowyAdmin();
    }
    
    // --- App Collections ---

    // Trips: public read + public update (for seat booking from app) + public create
    // (trip management done via app UI which has no Firebase Auth)
    match /trips/{trip} {
      allow read: if true;
      allow write: if true;
    }

    // Routes: public read + write (route/stop management done via app UI)
    match /routes/{route} {
      allow read: if true;
      allow write: if true;
    }

    match /vehicles/{vehicle} {
      allow read: if true;
      allow write: if true;
    }
    match /stops/{stop} {
      allow read: if true;
      allow write: if true;
    }
    match /tours/{tour} {
      allow read: if true;
      allow write: if true;
    }

    // Fare table: routeFares/{routeId}/fares/{fareDocId}
    // Public read so the booking form can look up fares without auth.
    // Public write so admin can manage fare tables from the app UI.
    match /routeFares/{routeId}/fares/{fareDocId} {
      allow read: if true;
      allow write: if true;
    }

    // Consignments: managed via app UI
    match /consignments/{consignment} {
      allow read, write: if true;
    }

    // Agents: public read + write (agent management done via app UI)
    match /agents/{agent} {
      allow read: if true;
      allow write: if true;
    }

    // Bookings: anyone can create a booking; all operations allowed for app UI
    match /bookings/{booking} {
      allow read, write: if true;
    }

    match /invoices/{invoice} {
      allow read, write: if true;
    }
    match /settings/{setting} {
      allow read, write: if true;
    }
  }
}